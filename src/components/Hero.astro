---

---

<section id="hero">
  <div class="container">
    <div class="hero-inner">
      <div>
        <div class="hero-badge fade-in">Available for work</div>
        <h1 class="hero-name fade-in">Doni<span class="accent">yor</span> Kuzy<span class="accent">baev</span></h1>
        <div class="hero-title fade-in">System Analyst · Project Manager</div>
        <p class="hero-desc fade-in">
          Превращаю сложные бизнес-процессы в работающие системы. Анализирую,
          проектирую, запускаю — от постановки задачи до деплоя.
        </p>
        <div class="hero-actions fade-in">
          <a href="#projects" class="btn-primary">Посмотреть проекты →</a>
          <a href="#contact" class="btn-secondary">Связаться</a>
        </div>
      </div>
      <div class="hero-card fade-in">
        <!-- <div class="card-label">// current_status.json</div> -->
        <div class="card-stat">
          <span class="stat-label">Experience</span><span
            class="stat-value orange">7+ years</span>
        </div>
        <div class="card-stat">
          <span class="stat-label">Location</span><span class="stat-value"
            >Remote / Worldwide</span>
        </div>
        <div class="card-stat">
          <span class="stat-label">Status</span><span class="stat-value green"
            >● open_to_work</span>
        </div>
        <div class="card-stat">
          <span class="stat-label">Age</span><span class="stat-value">31</span>
        </div>
        <div class="card-stat">
          <span class="stat-label">Languages</span><span class="stat-value"
            >RU / EN / UZ</span>
        </div>
        <div class="card-stat">
          <span class="stat-label">Methodology</span><span class="stat-value"
            >Agile / Scrum</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(1.3);
    }
  }
  #hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 120px 0 80px;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 80px;
    align-items: center;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--green);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 28px;
  }
  .hero-badge::before {
    content: "";
    width: 6px;
    height: 6px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  .hero-name {
    font-size: clamp(52px, 7vw, 88px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }
  .hero-name .accent {
    color: var(--accent);
  }
  .hero-title {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 32px;
  }
  .hero-desc {
    font-size: 17px;
    color: #9999aa;
    line-height: 1.7;
    max-width: 500px;
    margin-bottom: 48px;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .hero-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 32px;
    position: relative;
  }
  .hero-card::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 32px;
    width: 60px;
    height: 2px;
    background: var(--accent);
  }
  .card-label {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .card-stat {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  .card-stat:last-of-type {
    border-bottom: none;
  }
  .stat-label {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
  }
  .stat-value {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--text);
  }
  .stat-value.green {
    color: var(--green);
  }
  .stat-value.orange {
    color: var(--accent);
  }
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .hero-card {
      display: none;
    }
  }
</style>
